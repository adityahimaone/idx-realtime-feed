# --- Stockbit auth ---
STOCKBIT_USERNAME=
STOCKBIT_PASSWORD=
STOCKBIT_TOKEN_CACHE_PATH=.cache/stockbit_token.json

# --- Google Sheets (reuse dari Hermes Agent service account) ---
# Tempel JSON service account sebagai single-line string, sama seperti
# format .env.example di noczero/idx-fundamental-analysis
GOOGLE_SERVICE_ACCOUNT='{"type": "service_account", "project_id": "...", ...}'
MARKET_ALPHA_SPREADSHEET_ID=1wr2f6drQBqBUxikdJqSp1YVPaHF13qX0V3c7p4hkw5U
REALTIME_SHEET_NAME=Realtime_Watchlist
WATCHLIST_SHEET_NAME=Alpha_Watchlist

# --- Obscura CDP server ---
# Pastikan obscura jalan duluan: obscura serve --port 9222 --stealth
OBSCURA_CDP_URL=ws://127.0.0.1:9222

# --- Sync behaviour ---
SYNC_INTERVAL_SECONDS=45
MAX_WATCHLIST_SIZE=20

# --- Local cache ---
SQLITE_PATH=data/realtime_history.db
